# ─── NextAuth ───
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# ─── GitHub OAuth App ───
# Create at: https://github.com/settings/developers → New OAuth App
# → Homepage URL: http://localhost:3000
# → Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_ID=your-github-oauth-client-id
GITHUB_SECRET=your-github-oauth-client-secret

# ─── LinkedIn OAuth App ───
# Create at: https://www.linkedin.com/developers/apps → Create App
# → Under "Auth" tab, add redirect URLs (exact match, no trailing slash):
#     http://localhost:3000/api/auth/callback/linkedin
#     https://YOUR-VERCEL-DOMAIN/api/auth/callback/linkedin
# → Under "Products" tab, add "Sign In with LinkedIn using OpenID Connect"
#   (the app uses OIDC userinfo, not legacy /v2/me)
# Required on Vercel: Settings → Environment Variables → Production (not only Preview).
# Names must match exactly (or use LINKEDIN_CLIENT_ID / LINKEDIN_CLIENT_SECRET as fallback).
LINKEDIN_ID=your-linkedin-client-id
LINKEDIN_SECRET=your-linkedin-client-secret

# ─── GitHub Personal Access Token ───
# Create at: https://github.com/settings/tokens?type=beta (fine-grained)
# → Repository access: Only → muglikar/ProHealthLedger
# → Permissions: Contents (read/write), Issues (read/write)
GITHUB_PAT=your-github-pat-here

# ─── Repository ───
GITHUB_OWNER=muglikar
GITHUB_REPO=ProHealthLedger

# ─── Site admins (moderation + owner activity banner) ───
# github:muglikar is always an admin.
#
# LinkedIn admin — pick one (or combine) for your own account only:
#
# A) OAuth vanity from /v2/me: the app trusts verified vanity "muglikar" for admin (no env).
#    Other slugs: set LINKEDIN_ADMIN_IN_SLUGS (only if /v2/me returns vanityName for your token).
# LINKEDIN_ADMIN_IN_SLUGS=other-handle
# or full URL: LINKEDIN_ADMIN_IN_SLUGS=https://www.linkedin.com/in/other-handle/
#
# B) OIDC `sub`: after sign-in, hover nav name → Account: linkedin:… (often letters+digits like CAOSO1oig0).
#    Plain handle like `muglikar` (letters only) is treated as a public /in/ slug, not a sub — same as LINKEDIN_ADMIN_IN_SLUGS.
# LINKEDIN_ADMIN_SUBS=CAOSO1oig0
#
# Built-in LinkedIn admin is always linkedin:caoso1oig0 (public ledger) unless:
# DISABLE_BUILTIN_LINKEDIN_ADMIN=1
# Optional extra LinkedIn sub (in addition to the built-in):
# BUILTIN_LINKEDIN_ADMIN_SUB=other_sub_only
#
# Optional: exact email allowlist only (addresses you list — no substring matching).
# SITE_ADMIN_EMAILS=you@example.com
#
# Or full user ids: SITE_ADMIN_USER_IDS=github:other,linkedin:YOUR_SUB_HERE
SITE_ADMIN_EMAILS=
LINKEDIN_ADMIN_EMAILS=
LINKEDIN_ADMIN_IN_SLUGS=
LINKEDIN_ADMIN_SUBS=
SITE_ADMIN_USER_IDS=

# ─── Private redactions store (item 1.4) ───
# When a moderator rejects a comment, the original text is preserved here
# (not on the public ledger) so it can be restored on un-redact and reviewed
# in audit/regulator scenarios. The public ledger keeps a SHA-256 hash and
# every action is appended to data/moderation_log.json in the public repo.
#
# To enable: create a *private* GitHub repo (e.g. ProHealthLedger-redactions),
# give your GITHUB_PAT (or a separate one) Contents:read/write on it, then:
# GITHUB_REDACTIONS_OWNER=muglikar               # defaults to GITHUB_OWNER
# GITHUB_REDACTIONS_REPO=ProHealthLedger-redactions
# GITHUB_REDACTIONS_PAT=<separate-pat-or-omit-to-reuse-GITHUB_PAT>
#
# If unset, redaction still works (hash + clean public state) but the
# original text is NOT preserved and un-redact will fail.

# ─── Private removal-request intake store (item 1.7) ───
# Webform POST /api/removal-requests writes private request files here.
# Defaults to the redactions store if not set explicitly.
# GITHUB_REMOVALS_OWNER=muglikar
# GITHUB_REMOVALS_REPO=ProHealthLedger-removal-requests
# GITHUB_REMOVALS_PAT=<separate-pat-or-omit-to-reuse-redactions/main PAT>

# ─── Protected slugs from negative votes (item 1.8) ───
# Exact-match /in/ slugs only (no substring matching). Values may be either
# raw slugs or full LinkedIn URLs.
# PROTECTED_FROM_FLAG_SLUGS=muglikar,https://www.linkedin.com/in/example-handle/

# ─── Rate limiting (item 1.6) ───
# In-memory, per-server-instance. Good abuse damping, not global hard limits.
# Override only if you need tighter/looser controls.
# RL_SUBMIT_VOTE_LIMIT=5
# RL_SUBMIT_VOTE_WINDOW_MS=600000
# RL_SHARE_LINKEDIN_LIMIT=5
# RL_SHARE_LINKEDIN_WINDOW_MS=3600000
# RL_REFERRAL_CREATE_LIMIT=10
# RL_REFERRAL_CREATE_WINDOW_MS=3600000
# RL_REFERRAL_CLICK_LIMIT=60
# RL_REFERRAL_CLICK_WINDOW_MS=3600000
# RL_REFERRAL_SIGNUP_LIMIT=15
# RL_REFERRAL_SIGNUP_WINDOW_MS=3600000
# RL_MODERATE_LIMIT=60
# RL_MODERATE_WINDOW_MS=3600000
# RL_REMOVAL_REQUEST_LIMIT=5
# RL_REMOVAL_REQUEST_WINDOW_MS=3600000

# ─── Slug-existence verification (item 1.3) ───
# /api/submit-vote verifies that LinkedIn /in/<slug> resolves before recording
# a vote against a brand-new slug. If LinkedIn returns 404 we always block.
# When LinkedIn is rate-limiting our server (999 / 403 / 429 / 5xx / timeout)
# the response is "ambiguous"; default is to BLOCK after one retry.
#
# Set to "0" (or "false") to allow ambiguous responses through. Use this if
# legitimate submissions start failing because LinkedIn is throttling Vercel's
# egress. Should be paired with rate limiting before being left on long-term.
# SLUG_VERIFY_BLOCK_AMBIGUOUS=1
