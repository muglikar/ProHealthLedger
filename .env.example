# ─── NextAuth ───
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# ─── GitHub OAuth App ───
# Create at: https://github.com/settings/developers → New OAuth App
# → Homepage URL: http://localhost:3000
# → Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_ID=your-github-oauth-client-id
GITHUB_SECRET=your-github-oauth-client-secret

# ─── LinkedIn OAuth App ───
# Create at: https://www.linkedin.com/developers/apps → Create App
# → Under "Auth" tab, add redirect URLs (exact match, no trailing slash):
#     http://localhost:3000/api/auth/callback/linkedin
#     https://YOUR-VERCEL-DOMAIN/api/auth/callback/linkedin
# → Under "Products" tab, add "Sign In with LinkedIn using OpenID Connect"
#   (the app uses OIDC userinfo, not legacy /v2/me)
# Required on Vercel: Settings → Environment Variables → Production (not only Preview).
# Names must match exactly (or use LINKEDIN_CLIENT_ID / LINKEDIN_CLIENT_SECRET as fallback).
LINKEDIN_ID=your-linkedin-client-id
LINKEDIN_SECRET=your-linkedin-client-secret

# ─── GitHub Personal Access Token ───
# Create at: https://github.com/settings/tokens?type=beta (fine-grained)
# → Repository access: Only → muglikar/ProHealthLedger
# → Permissions: Contents (read/write), Issues (read/write)
GITHUB_PAT=your-github-pat-here

# ─── Repository ───
GITHUB_OWNER=muglikar
GITHUB_REPO=ProHealthLedger

# ─── Site admins (moderation + owner activity banner) ───
# github:muglikar is always an admin.
#
# Easiest for LinkedIn: set SITE_ADMIN_EMAILS to the same email LinkedIn returns
# (Sign in with LinkedIn must include the email scope; check the account line in nav).
# SITE_ADMIN_EMAILS=you@company.com,you@gmail.com
#
# LinkedIn users with "muglikar" in display name or email are treated as admins unless you set:
# DISABLE_MUGLIKAR_TRUSTED_LINKEDIN_ADMIN=1
#
# Or use OIDC sub after "linkedin:" (case-insensitive):
# LINKEDIN_ADMIN_SUBS=your_sub_from_linkedin
# Or full ids: SITE_ADMIN_USER_IDS=github:other,linkedin:YOUR_SUB_HERE
SITE_ADMIN_EMAILS=
LINKEDIN_ADMIN_EMAILS=
LINKEDIN_ADMIN_SUBS=
SITE_ADMIN_USER_IDS=
